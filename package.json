{
  "name": "mcp-typescript-project",
  "version": "3.0.0",
  "description": "MCP architecture demo using the official @modelcontextprotocol/sdk",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:server": "node build/server/nls.js",
    "start:host": "node build/host/app.js",
    "dev:server": "tsx src/server/nls.ts",
    "dev:server:http": "tsx src/server/http.ts",
    "dev:host": "tsx src/host/app.ts",
    "dev:api": "tsx src/api/server.ts",
    "test": "vitest run",
    "wiki": "tsx src/scripts/wiki.ts",
    "pyramid": "tsx src/scripts/pyramid.ts",
    "league-scraper": "tsx src/scripts/league-scraper.ts",
    "wikipedia-section": "tsx src/scripts/wikipedia-section.ts",
    "wikipedia-check": "tsx src/scripts/wikipedia-check.ts",
    "wikipedia-fix": "tsx src/scripts/wikipedia-fix.ts",
    "wikipedia-club-check": "tsx src/scripts/wikipedia-club-check.ts",
    "dev:web": "cd web && npm run dev",
    "start:server:http": "node build/server/http.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cheerio": "^1.2.0",
    "chronium": "^0.0.6",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "playwright": "^1.59.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
